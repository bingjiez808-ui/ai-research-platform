{
  "name": "ai-research-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "dev:all": "node server/index.js & vite",
    "build": "vite build",
    "start": "node --env-file-if-exists=.env server/index.js",
    "lint": "oxlint",
    "test": "NODE_ENV=test node --test",
    "preview": "vite preview",
    "db:migrate": "prisma migrate deploy",
    "ingest": "node --env-file-if-exists=.env scripts/ingest-research.js",
    "db:generate": "prisma generate",
    "db:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "finance:open": "node --env-file-if-exists=.env scripts/finance-job.js open",
    "finance:close": "node --env-file-if-exists=.env scripts/finance-job.js close",
    "finance:nightly": "node --env-file-if-exists=.env scripts/finance-job.js nightly",
    "finance:job": "node --env-file-if-exists=.env scripts/finance-job.js",
    "production:job": "node --env-file-if-exists=.env scripts/run-production-job.js",
    "scheduler:start": "node --env-file-if-exists=.env scripts/scheduler-daemon.js",
    "tushare:sync": "node --env-file-if-exists=.env scripts/tushare-sync.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.18.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "node-cron": "^4.2.1",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "prisma": "^7.8.0",
    "vite": "^8.1.1"
  }
}

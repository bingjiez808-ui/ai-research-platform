# Production market-data providers
TUSHARE_TOKEN=
TUSHARE_API_URL=https://api.tushare.pro
TUSHARE_RETRY_ATTEMPTS=3
TUSHARE_MAX_RETRY_DELAY_MS=60000
TUSHARE_WATCHLIST=000001.SZ,600519.SH
AKSHARE_WORKER_URL=http://akshare-worker:8000
AKSHARE_TIMEOUT_MS=60000
CNINFO_ENABLED=true
CNINFO_PAGE_SIZE=50
CNINFO_LOOKBACK_DAYS=7

# A-share ingestion (real Eastmoney public endpoints; no mock fallback)
FINANCE_WATCHLIST=600519,000001
FINANCE_QUOTE_BATCH_SIZE=500
LIVE_UNIVERSE_BOOTSTRAP=true
FINANCE_HTTP_TIMEOUT_MS=15000
FINANCE_USER_AGENT=ai-research-platform/1.0 (researcher@example.com)
# Optional future LLM extension. When unset, analysis is explicitly deterministic rules.
FINANCE_LLM_PROVIDER=
FINANCE_LLM_API_KEY=
FINANCE_LLM_BASE_URL=https://api.openai.com/v1
FINANCE_LLM_MODEL=
FINANCE_LLM_TEMPERATURE=0.15
FINANCE_LLM_TIMEOUT_MS=60000

# Required: PostgreSQL connection used by the app.
# Supabase production example (transaction pooler, port 6543):
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_research

# Recommended for Prisma migrations on Supabase (direct/session connection, port 5432).
# Falls back to DATABASE_URL when omitted.
# DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DIRECT_URL=

PG_SSL=false
PG_POOL_MAX=10

# Optional provider credentials. Public data works without them, but quotas are lower.
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_API_KEY=
OPENALEX_EMAIL=researcher@example.com
HUGGINGFACE_TOKEN=

# Networking and ingestion controls
RESEARCH_USER_AGENT=ai-research-platform/1.0 (researcher@example.com)
RESEARCH_HTTP_TIMEOUT_MS=15000
RESEARCH_HTTP_RETRIES=3
INGEST_LIMIT=50

# Production scheduler
SCHEDULER_ENABLED=false
SCHEDULER_TIMEZONE=Asia/Shanghai
SCHEDULER_MAX_RETRY_DELAY_MS=60000

# Licensed CLS connector. Do not scrape around access controls.
CLS_API_URL=
CLS_API_KEY=

# OpenAI-compatible embedding endpoint. If absent, embedding is explicitly skipped.
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_TIMEOUT_MS=30000

# Restrict cross-origin callers in production (comma-separated).
CORS_ORIGIN=

# OpenAI-compatible vision/OCR endpoint. Portfolio screenshots are sent only
# after an explicit user upload action.
OCR_API_URL=https://api.openai.com/v1/chat/completions
OCR_API_KEY=
OCR_MODEL=gpt-4.1-mini
OCR_TIMEOUT_MS=60000
